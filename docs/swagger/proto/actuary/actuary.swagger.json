{
  "swagger": "2.0",
  "info": {
    "title": "proto/actuary/actuary.proto",
    "version": "version not set"
  },
  "tags": [
    {
      "name": "ActuaryService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/actuary/agents": {
      "get": {
        "summary": "GetAgents — Supervisor only.\nReturns the list of agents visible in the actuary management portal.\nSupports optional partial-match filters on email, first_name, last_name, position.",
        "operationId": "ActuaryService_GetAgents",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetAgentsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "email",
            "description": "partial match, case-insensitive; \"\" = no filter",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "firstName",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "lastName",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "position",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "ActuaryService"
        ]
      }
    },
    "/actuary/agents/{employeeId}/limit": {
      "patch": {
        "summary": "SetAgentLimit — Supervisor only.\nUpdates the daily spending limit for the specified agent.",
        "operationId": "ActuaryService_SetAgentLimit",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "type": "object",
              "properties": {}
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "employeeId",
            "description": "target agent identified by employee_id",
            "in": "path",
            "required": true,
            "type": "string",
            "format": "int64"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ActuaryServiceSetAgentLimitBody"
            }
          }
        ],
        "tags": [
          "ActuaryService"
        ]
      }
    },
    "/actuary/agents/{employeeId}/need-approval": {
      "patch": {
        "summary": "SetAgentNeedApproval — Supervisor only.\nSets or clears the need_approval flag for the specified agent.",
        "operationId": "ActuaryService_SetAgentNeedApproval",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "type": "object",
              "properties": {}
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "employeeId",
            "description": "target agent identified by employee_id",
            "in": "path",
            "required": true,
            "type": "string",
            "format": "int64"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ActuaryServiceSetAgentNeedApprovalBody"
            }
          }
        ],
        "tags": [
          "ActuaryService"
        ]
      }
    },
    "/actuary/agents/{employeeId}/reset-limit": {
      "post": {
        "summary": "ResetAgentUsedLimit — Supervisor only.\nResets the agent's used_limit to 0 (manual daily reset).",
        "operationId": "ActuaryService_ResetAgentUsedLimit",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "type": "object",
              "properties": {}
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "employeeId",
            "description": "target agent identified by employee_id",
            "in": "path",
            "required": true,
            "type": "string",
            "format": "int64"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ActuaryServiceResetAgentUsedLimitBody"
            }
          }
        ],
        "tags": [
          "ActuaryService"
        ]
      }
    },
    "/actuary/employee/{employeeId}": {
      "get": {
        "summary": "GetActuaryByEmployeeID — Supervisor only (internal use).\nReturns ActuaryInfo for the specified employee, or NOT_FOUND if they are not an actuary.",
        "operationId": "ActuaryService_GetActuaryByEmployeeID",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetActuaryByEmployeeIDResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "employeeId",
            "in": "path",
            "required": true,
            "type": "string",
            "format": "int64"
          }
        ],
        "tags": [
          "ActuaryService"
        ]
      }
    },
    "/actuary/me": {
      "get": {
        "summary": "GetMyActuaryInfo — Actuary only (supervisor or agent).\nReturns the ActuaryInfo record for the calling employee.",
        "operationId": "ActuaryService_GetMyActuaryInfo",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetMyActuaryInfoResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "tags": [
          "ActuaryService"
        ]
      }
    }
  },
  "definitions": {
    "ActuaryServiceResetAgentUsedLimitBody": {
      "type": "object"
    },
    "ActuaryServiceSetAgentLimitBody": {
      "type": "object",
      "properties": {
        "limit": {
          "type": "number",
          "format": "double",
          "title": "new limit value (\u003e= 0)"
        }
      }
    },
    "ActuaryServiceSetAgentNeedApprovalBody": {
      "type": "object",
      "properties": {
        "needApproval": {
          "type": "boolean"
        }
      }
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1ActuaryInfo": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "int64",
          "title": "PK of the actuary_info record"
        },
        "employeeId": {
          "type": "string",
          "format": "int64",
          "title": "FK → users table (employee)"
        },
        "actuaryType": {
          "$ref": "#/definitions/v1ActuaryType"
        },
        "limit": {
          "type": "number",
          "format": "double",
          "title": "daily spending limit (RSD); 0 = no limit (supervisor)"
        },
        "usedLimit": {
          "type": "number",
          "format": "double",
          "title": "amount consumed today; reset at 23:59 or manually"
        },
        "needApproval": {
          "type": "boolean",
          "title": "if true, all agent orders need supervisor approval"
        }
      },
      "description": "ActuaryInfo is the extension record stored alongside an Employee.\nSupervisors always have limit=0, used_limit=0, need_approval=false."
    },
    "v1ActuaryType": {
      "type": "string",
      "enum": [
        "ACTUARY_TYPE_UNSPECIFIED",
        "ACTUARY_TYPE_SUPERVISOR",
        "ACTUARY_TYPE_AGENT"
      ],
      "default": "ACTUARY_TYPE_UNSPECIFIED",
      "description": "ActuaryType distinguishes supervisors (no limit, always approved) from\nagents (have a daily limit and may require approval)."
    },
    "v1AgentListItem": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "int64",
          "title": "actuary_info id"
        },
        "employeeId": {
          "type": "string",
          "format": "int64"
        },
        "email": {
          "type": "string"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "position": {
          "type": "string"
        },
        "limit": {
          "type": "number",
          "format": "double"
        },
        "usedLimit": {
          "type": "number",
          "format": "double"
        },
        "needApproval": {
          "type": "boolean"
        }
      },
      "description": "AgentListItem is the per-row projection for the supervisor portal.\nCombines ActuaryInfo fields with identifying user fields (fetched from user-service)."
    },
    "v1GetActuaryByEmployeeIDResponse": {
      "type": "object",
      "properties": {
        "actuary": {
          "$ref": "#/definitions/v1ActuaryInfo"
        }
      }
    },
    "v1GetAgentsResponse": {
      "type": "object",
      "properties": {
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1AgentListItem"
          }
        }
      }
    },
    "v1GetMyActuaryInfoResponse": {
      "type": "object",
      "properties": {
        "actuary": {
          "$ref": "#/definitions/v1ActuaryInfo"
        }
      }
    }
  }
}
