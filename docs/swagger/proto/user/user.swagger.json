        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1CreateClientRequest"
            }
          }
        ],
        "tags": [
          "UserService"
        ]
      }
    },
    "/client/search": {
      "get": {
        "summary": "SearchClients — Employee only.\nSearches clients by first/last name or email for Autocomplete and\nInfinite Scroll on the account-creation form.\nEmpty query returns all clients (paginated).",
        "operationId": "UserService_SearchClients",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1SearchClientsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "query",
            "description": "partial match on first_name, last_name, or email; \"\" = return all",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "page",
            "description": "1-indexed; 0 is treated as 1",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "limit",
            "description": "page size; 0 is treated as 10",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          }
        ],
        "tags": [
          "UserService"
        ]
      }
    },
