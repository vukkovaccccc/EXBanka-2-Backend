    "/client": {
      "get": {
        "summary": "ListClients — Employee only.\nReturns a paginated, alphabetically-sorted list of clients for the\nmanagement portal.  Supports optional name and email filters.",
        "operationId": "UserService_ListClients",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListClientsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "name",
            "description": "partial match on first_name, last_name, or \"first last\"; \"\" = no filter",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "email",
            "description": "partial match on email; \"\" = no filter",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "limit",
            "description": "page size; 0 treated as 20",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "offset",
            "description": "skip N results; 0 = from start",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          }
        ],
        "tags": [
          "UserService"
        ]
      },
      "post": {
        "summary": "CreateClient — Employee only.\nCreates a new physical client account (no password). An activation email\nis sent asynchronously via the Notification service.",
        "operationId": "UserService_CreateClient",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
